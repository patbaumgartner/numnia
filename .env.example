# Numnia — environment overrides for docker compose.
# Copy to `.env` and adjust as needed.

# Database
POSTGRES_DB=numnia
POSTGRES_USER=numnia
POSTGRES_PASSWORD=numnia
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Object storage (MinIO, interim per ADR-001)
MINIO_ROOT_USER=numnia
MINIO_ROOT_PASSWORD=numnia-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Application ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
