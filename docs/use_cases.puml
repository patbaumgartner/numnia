}

' ===== Release 4 (LiveOps & content) =====
rectangle "Release 4 - LiveOps & content expansion" {
  usecase "UC-038 Configure task pool"                    as UC038
  usecase "UC-039 Configure season"                       as UC039
  usecase "UC-040 Boss portal"                            as UC040
  usecase "UC-041 Child collects\nseason rewards"         as UC041
  usecase "UC-042 Release new world\n(friendly design)"   as UC042
