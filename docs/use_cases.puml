@startuml use_cases
!option handwritten false
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor     #1F2937
  ArrowColor      #1F2937
}

title Numnia - Use Cases (Releases 1-5 + Legal)

' ===== Actors =====
actor "Visitor"            as Visitor
actor "Child"              as Child
actor "Parent"             as Parent
actor "Teacher"            as Teacher
actor "School Admin"       as SchoolAdmin
actor "Content Manager"    as ContentMgr
actor "Support / Moderator" as Support
actor "System Admin / Operator" as Operator
actor "Adaptive Engine"    as Adaptive <<system>>
actor "Matchmaking"        as Matchmaking <<system>>
actor "Moderation Service" as ModSvc <<system>>
actor "Email Service"      as Mail <<system>>
actor "Data Protection Officer" as DPO

' ===== Release 1 (MVP) =====
rectangle "Release 1 - safe MVP" {
  usecase "UC-001 Set up parent account\nand child profile (double opt-in)" as UC001
  usecase "UC-002 Child signs in\nto child profile"                          as UC002
  usecase "UC-003 Child starts\ntraining mode"                               as UC003
  usecase "UC-004 Child practices in\naccuracy mode"                         as UC004
  usecase "UC-005 Child enters a world\nthrough a portal"                    as UC005
  usecase "UC-006 Child unlocks creature\nand picks companion"               as UC006
