rectangle "Release 5 - full target build-out" {
  usecase "UC-045 Browse full\n24-world catalog"        as UC045
  usecase "UC-046 Full creature\nevolution gallery"     as UC046
  usecase "UC-047 Toolchain and\noperations review"     as UC047
