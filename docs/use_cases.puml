  usecase "UC-008 Child views own\nlearning progress"                        as UC008
  usecase "UC-009 Parent sets daily limit\nand risk mechanic"                as UC009
  usecase "UC-010 Parent exports\nchild data"                                as UC010
  usecase "UC-011 Parent deletes\nchild account"                             as UC011
  usecase "UC-012 Child uses\naccessibility mode"                            as UC012
  usecase "UC-013 Child receives\nexplanation mode"                          as UC013
  usecase "UC-014 Child plays\nsprint mode"                                  as UC014
  usecase "UC-015 Child plays\nlevel mode"                                   as UC015
  usecase "UC-016 Child achieves daily\nand weekly goals"                    as UC016
  usecase "UC-017 Spaced repetition\nretest probe"                           as UC017
  usecase "UC-018 Parent unlocks multiplayer\nvia second consent"            as UC018
  usecase "UC-019 Child views\ncreature gallery"                             as UC019
  usecase "UC-020 Child picks\nfantasy display name"                         as UC020
}

